NODE_ENV=production

# IIS/iisnode usually injects PORT automatically.
# Set this only if your host requires a fixed port.
# PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/gtpms

# JWT secrets: replace all of these with long random values before going live.
JWT_SECRET=replace-with-a-long-random-fallback-secret
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# Token lifetimes
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=90d

# Allowed browser origins. For same-domain IIS deploy, use your public domain.
# CORS_ORIGIN=https://pms.gitakshmi.com,https://www.pms.gitakshmi.com
CORS_ORIGIN=http://localhost:5173
# Logging / hashing
LOG_LEVEL=info
BCRYPT_ROUNDS=12

# Frontend build directory relative to the deployed server app root.
# Recommended IIS/Plesk layout: copy client/dist into server/public
CLIENT_DIST_DIR=public

# Initial super admin bootstrap for a fresh database.
BOOTSTRAP_SUPER_ADMIN_EMAIL=gitakshmi@gmail.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=Gitakshmi@123
BOOTSTRAP_SUPER_ADMIN_NAME=Dhiren Makwana
BOOTSTRAP_SUPER_ADMIN_WORKSPACE=Gitakshmi Technologies
